# Basic runtime
NODE_ENV=production
LOG_LEVEL=info
HEADLESS=true
TIMEZONE=Asia/Shanghai

# Default cron: 09:15 every day.
CHECKIN_CRON=15 9 * * *

# Persisted runtime data inside Docker.
DATA_DIR=/app/data

# Keep a success screenshot too. Failure screenshots are always saved.
SCREENSHOT_ON_SUCCESS=false

# When a challenge page is detected, wait before marking the run as failed.
# Use this with a visible/headed browser or a future remote desktop setup.
HANDOFF_TIMEOUT_SECONDS=0

# Optional JSON override. If unset, config/config.json is used.
# CHECKIN_SITES_JSON=[{"id":"elysiver","name":"elysiver","baseUrl":"https://elysiver.h-e.top","personalPath":"/console/personal"}]
